PREPSUITE_APP_NAME=PrepSuite Backend
PREPSUITE_ENVIRONMENT=production
PREPSUITE_DEBUG=false
PREPSUITE_API_V1_PREFIX=/api/v1
PREPSUITE_DATABASE_URL=postgresql+asyncpg://PREPSUITE_APP_USER:CHANGE_ME@postgres:5432/prepsuite
PREPSUITE_MIGRATION_DATABASE_URL=postgresql+asyncpg://PREPSUITE_OWNER_USER:CHANGE_ME@postgres:5432/prepsuite
PREPSUITE_REDIS_URL=redis://redis:6379/0
PREPSUITE_CORS_ORIGINS=[]
PREPSUITE_TRUSTED_HOSTS=["api.prepsuite.in"]
PREPSUITE_LOG_LEVEL=INFO
PREPSUITE_JWT_ISSUER=prepsuite
PREPSUITE_JWT_AUDIENCE=prepsuite-api
PREPSUITE_JWT_PRIVATE_KEY_PEM=CHANGE_ME_MULTILINE_OR_SECRET_MANAGER
PREPSUITE_JWT_PUBLIC_KEY_PEM=CHANGE_ME_MULTILINE_OR_SECRET_MANAGER
PREPSUITE_ACCESS_TOKEN_TTL_MINUTES=15
PREPSUITE_REFRESH_TOKEN_TTL_DAYS=30
