PREPSUITE_APP_NAME=PrepSuite Backend
PREPSUITE_ENVIRONMENT=test
PREPSUITE_DEBUG=false
PREPSUITE_API_V1_PREFIX=/api/v1
PREPSUITE_DATABASE_URL=postgresql+asyncpg://prepsuite_app:prepsuite_app@localhost:5433/prepsuite_test
PREPSUITE_MIGRATION_DATABASE_URL=postgresql+asyncpg://prepsuite_owner:prepsuite_owner@localhost:5433/prepsuite_test
PREPSUITE_REDIS_URL=redis://localhost:6380/0
PREPSUITE_CORS_ORIGINS=["http://testserver"]
PREPSUITE_TRUSTED_HOSTS=["testserver","localhost","127.0.0.1"]
PREPSUITE_LOG_LEVEL=WARNING
