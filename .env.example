PREPSUITE_APP_NAME=PrepSuite Backend
PREPSUITE_ENVIRONMENT=local
PREPSUITE_DEBUG=true
PREPSUITE_API_V1_PREFIX=/api/v1
PREPSUITE_DATABASE_URL=postgresql+asyncpg://prepsuite:prepsuite@localhost:5432/prepsuite
PREPSUITE_REDIS_URL=redis://localhost:6379/0
PREPSUITE_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
PREPSUITE_TRUSTED_HOSTS=["localhost","127.0.0.1","0.0.0.0","prepsuite-api"]
PREPSUITE_LOG_LEVEL=INFO
